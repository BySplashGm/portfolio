<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}{% endblock %} | Maxime's Portfolio</title>
    <meta name="description" content="{% block meta_description %}Maxime Valin — Étudiant en Licence MIAGE, développeur passionné d'informatique, de voitures et de musique.{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}">

    <!-- Open Graph / Social preview -->
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:site_name" content="Maxime's Portfolio">
    <meta property="og:title" content="{% block og_title %}{{ block('title') }} | Maxime's Portfolio{% endblock %}">
    <meta property="og:description" content="{{ block('meta_description') }}">
    <meta property="og:url" content="{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('images/moi.png')) }}{% endblock %}">
    <meta property="og:locale" content="fr_FR">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('meta_description') }}">
    <meta name="twitter:image" content="{{ block('og_image') }}">

    <link rel="icon" href="{{ asset('favicon.png') }}">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5/dist/fancybox/fancybox.css"/>
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
{% set currentRoute = app.request.attributes.get('_route') %}
<header id="top">
    <nav aria-label="Navigation principale">
        <div class="logo">
            <span class="devlogo" aria-hidden="true">&lt;/&gt;</span><span>Maxime's Portfolio</span>
        </div>
        <ul>
            <li><a href="{{ path('index') }}"{% if currentRoute == 'index' %} aria-current="page"{% endif %}>Accueil</a></li>
            <li><a href="{{ path('about') }}"{% if currentRoute == 'about' %} aria-current="page"{% endif %}>À propos</a></li>
            <li><a href="{{ path('projects') }}"{% if currentRoute in ['projects', 'project'] %} aria-current="page"{% endif %}>Projets</a></li>
            <li><a href="{{ path('contact') }}"{% if currentRoute == 'contact' %} aria-current="page"{% endif %}>Contact</a></li>
        </ul>
    </nav>
    {% set flashes = app.flashes('success') %}
    {% if flashes %}
        <div class="flash-success" role="status">
            {% for message in flashes %}
                <p>{{ message }}</p>
            {% endfor %}
        </div>
    {% endif %}
</header>

{% block body %}{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5/dist/fancybox/fancybox.umd.js"></script>
<script>
    function initFancybox() {
        document.querySelectorAll('.rich-content img').forEach(function (img) {
            if (img.parentElement.tagName !== 'A') {
                var a = document.createElement('a');
                a.href = img.src;
                a.dataset.fancybox = 'gallery';
                img.parentNode.insertBefore(a, img);
                a.appendChild(img);
            }
        });
        Fancybox.bind('[data-fancybox]');
    }

    document.addEventListener('DOMContentLoaded', initFancybox);
    document.addEventListener('turbo:load', initFancybox);
</script>
<footer>
    <div class="logo-footer">
        <span>{{ site_name | default('Maxime\'s Portfolio') }}</span>
    </div>
    <div class="footer-content">
        <!-- Section gauche : Réseaux sociaux et retour en haut -->
        <div class="footer-left">
            <div class="footer-sp">
                <ul>
                    <li><a href="https://github.com/BySplashGm" target="_blank" rel="noopener noreferrer"><i class="fab fa-github" aria-hidden="true"></i> GitHub</a></li>
                    <li><a href="https://www.linkedin.com/in/maximevalin/" target="_blank" rel="noopener noreferrer"><i class="fab fa-linkedin" aria-hidden="true"></i> LinkedIn</a></li>
                </ul>
            </div>
            <div class="back-to-top">
                <a href="#top"><i class="fas fa-arrow-up" aria-hidden="true"></i> Retour en haut</a>
            </div>
        </div>
        <!-- Section centrale : Navigation -->
        <div class="footer-center">
            <nav class="footer-links" aria-label="Navigation secondaire">
                <ul>
                    <li><a href="{{ path('index') }}">Accueil</a></li>
                    <li><a href="{{ path('about') }}">À propos</a></li>
                    <li><a href="{{ path('projects') }}">Projets</a></li>
                    <li><a href="{{ path('contact') }}">Contact</a></li>
                </ul>
            </nav>
        </div>
        <!-- Section droite : Informations supplémentaires -->
        <div class="footer-right">
            <p>{{ custom_message | default('Envie de collaborer ? Contactez-moi via la page dédiée ou sur mes réseaux !') }}</p>
        </div>
    </div>
    <!-- Bas de page -->
    <div class="footer-bottom">
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin') }}" target="_blank" rel="noopener noreferrer">Panel Admin</a>
            <a href="{{ path('app_logout') }}">Déconnexion</a>
        {% endif %}
        <p>&copy; {{ "now"|date("Y") }} {{ site_name | default('Maxime\'s Portfolio') }}. Tous droits réservés.</p>
    </div>
</footer>
</body>
</html>
