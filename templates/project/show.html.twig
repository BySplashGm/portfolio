{% extends 'base.html.twig' %}
{% block title %}{{ project.name }}{% endblock %}
{% block meta_description %}{{ project.shortDescription }}{% endblock %}
{% block og_type %}article{% endblock %}
{% block og_image %}{% if project.imagePath %}{{ absolute_url(asset(project.imagePath)) }}{% else %}{{ absolute_url(asset('images/moi.png')) }}{% endif %}{% endblock %}
{% block body %}
    <main>
        <section class="details-section">
            <h1 class="details-title">{{ project.name }}</h1>
            <div class="details-content">
                <div class="project-description">
                    <div class="rich-content">{{ content|raw }}</div>
                </div>
                <aside class="details-sidebar">
                    <div class="details-additional-info">
                        {% if project.skills is not empty %}
                            <h2>Compétences</h2>
                            <ul class="skills-list">
                                {% for skill in project.skills %}
                                    <li><a href="{{ path('skill_show', {'id': skill.id}) }}">{{ skill.name }}</a></li>
                                {% endfor %}
                            </ul>
                        {% endif %}

                        {% if project.createdAt %}
                            <p class="project-date">Créé le : {{ project.createdAt|date('d/m/Y') }}</p>
                        {% endif %}
                        {% if project.repolink %}
                            <p><a href="{{ project.repolink }}" target="_blank" rel="noopener noreferrer" class="experience-link">Repository Git</a></p>
                        {% endif %}
                        {% if project.link %}
                            <p><a href="{{ project.link }}" target="_blank" rel="noopener noreferrer" class="experience-link">Voir le projet en ligne</a></p>
                        {% endif %}
                    </div>
                </aside>
            </div>
            <a href="{{ path('projects') }}" class="back-to-projects">← Retour aux projets</a>
        </section>
    </main>
{% endblock %}
