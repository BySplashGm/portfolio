{% extends 'base.html.twig' %}
{% block title %}{{ skill.name }}{% endblock %}
{% block meta_description %}Compétence {{ skill.name }} — projets et expériences associés dans le portfolio de Maxime Valin.{% endblock %}
{% block body %}
    <main>
        <div class="skill-header">
            <h1>{{ skill.name }}</h1>
        </div>

        <section class="skill-related-section">
            <h2>Projets associés à {{ skill.name }}</h2>
            {% if skill.projects is not empty %}
                <div class="related-list">
                    {% for project in skill.projects %}
                        <div class="related-item">
                            <h3>{{ project.name }}</h3>
                            <p>{{ project.shortDescription }}</p>
                            <a href="{{ path('project', {'id': project.id}) }}" class="btn">Voir le projet</a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucun projet associé à cette compétence pour le moment.</p>
            {% endif %}
        </section>

        <section class="skill-related-section">
            <h2>Expériences associées à {{ skill.name }}</h2>
            {% if skill.experiences is not empty %}
                <div class="related-list">
                    {% for experience in skill.experiences %}
                        <div class="related-item">
                            <h3>{{ experience.label }}</h3>
                            <p>{{ experience.shortDescription }}</p>
                            <a href="{{ path('experience_show', {'id': experience.id}) }}" class="btn">Voir l'expérience</a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucune expérience associée à cette compétence pour le moment.</p>
            {% endif %}
        </section>
    </main>
{% endblock %}
